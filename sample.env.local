# OpenAI conversion provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Default provider: openai, mock, or codex-local
DOCUTOR_LLM_PROVIDER=openai

# Optional local runtime settings
DOCUTOR_PYTHON_BIN=python3
DOCUTOR_ENABLE_CODEX_LOCAL=0
CODEX_MODEL=

# App mode: hosted (default) sends uploads straight to the LLM provider via
# /api/convert-direct and works on serverless platforms like Vercel with no
# extra system deps. self-hosted routes uploads through the full server
# pipeline (/api/documents -> .../convert), which uses the Python worker
# (LibreOffice/poppler) for real page-image extraction and normalization;
# it requires those system dependencies to be installed.
NEXT_PUBLIC_DOCUTOR_MODE=hosted

# draw.io embed host used by the diagram editor. Defaults to the public
# embed.diagrams.net service; point it at a self-hosted draw.io instance to
# keep diagram XML in-house (this also skips the external-send consent
# prompt shown for the public host).
NEXT_PUBLIC_DRAWIO_EMBED_URL=https://embed.diagrams.net
